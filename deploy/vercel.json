**4. Crée la fonction sanitizeInput dans src/utils/sanitize.ts**
```typescript
function sanitizeInput(str: string) {
  return str
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#x27;');
}

export default sanitizeInput;
```

