Je vais créer les deux fichiers complets pour la gestion sécurisée des secrets.

**Fichier 1: src/config/apiConfig.js**

const REQUIRED_KEYS = [
  'VITE_API_BASE_URL',
  'VITE_API_KEY',
  'VITE_SUPABASE_URL',
  'VITE_SUPABASE_ANON_KEY',
  'VITE_OPENAI_API_KEY',
];

const OPTIONAL_KEYS = [
  'VITE_STRIPE_PUBLISHABLE_KEY',
  'VITE_SENTRY_DSN',
  'VITE_ANALYTICS_ID',
  'VITE_FEATURE_FLAGS',
  'VITE_APP_ENV',
  'VITE_APP_VERSION',
];

function validateEnvironment() {
  const missing = [];
  const invalid = [];

  for (const key of REQUIRED_KEYS) {
    const value = import.meta.env[key];

    if (value === undefined || value === null || value === '') {
      missing.push(key);
      continue;
    }

    if (typeof value !== 'string') {
      invalid.push({ key, reason: 'must be a string' });
      continue;
    }

    if (key.includes('URL') && value !== '') {
      try {
        new URL(value);
      } catch {
        invalid.push({ key, reason: `invalid URL format: "${value}"` });
      }
    }

    if (key.includes('API_KEY') || key.includes('ANON_KEY') || key.includes('SECRET')) {
      if (value.length < 8) {
        invalid.push({ key, reason: 'secret key appears too short (< 8 chars)' });
      }
    }
  }

  if (missing.length > 0 || invalid.length > 0) {
    const lines = [
      '╔════════════════════════════════════════════════════════════╗',
      '║         TRACKR — ENVIRONMENT VALIDATION FAILED             ║',
      '╚════════════════════════════════════════════════════════════╝',
    ];

    if (missing.length > 0) {
      lines.push('');
      lines.push('  ❌  MISSING REQUIRED VARIABLES:');
      for (const key of missing) {
        lines.push(`       • ${key}`);
      }
    }

    if (invalid.length > 0) {
      lines.push('');
      lines.push('  ⚠️   INVALID VARIABLE VALUES:');
      for (const { key, reason } of invalid) {
        lines.push(`       • ${key} — ${reason}`);
      }
    }

    lines.push('');
    lines.push('  📄  See .env.example for the full list of required variables.');
    lines.push('  📄  Copy .env.example to .env.local and fill in the values.');
    lines.push('');

    const message = lines.join('\n');

    if (import.meta.env.MODE === 'production') {
      throw new Error(message);
    } else {
      console.error(message);
      if (missing.length > 0) {
        throw new Error(
          `[Trackr] Build aborted — ${missing.length} required env variable(s) missing. Check console for details.`
        );
      }
    }
  }

  const warnings = [];
  for (const key of OPTIONAL_KEYS) {
    if (!import.meta.env[key]) {
      warnings.push(key);
    }
  }

  if (warnings.length > 0 && import.meta.env.MODE !== 'test') {
    console.warn(
      `[Trackr] Optional env variables not set: ${warnings.join(', ')}`
    );
  }
}

validateEnvironment();

const _env = Object.freeze({
  apiBaseUrl:            import.meta.env.VITE_API_BASE_URL,
  apiKey:                import.meta.env.VITE_API_KEY,
  supabaseUrl:           import.meta.env.VITE_SUPABASE_URL,
  supabaseAnonKey:       import.meta.env.VITE_SUPABASE_ANON_KEY,
  openaiApiKey:          import.meta.env.VITE_OPENAI_API_KEY,
  stripePublishableKey:  import.meta.env.VITE_STRIPE_PUBLISHABLE_KEY  ?? null,
  sentryDsn:             import.meta.env.VITE_SENTRY_DSN              ?? null,
  analyticsId:           import.meta.env.VITE_ANALYTICS_ID            ?? null,
  featureFlags:          import.meta.env.VITE_FEATURE_FLAGS           ?? null,
  appEnv:                import.meta.env.VITE_APP_ENV                 ?? 'development',
  appVersion:            import.meta.env.VITE_APP_VERSION             ?? '0.0.0',
  mode:                  import.meta.env.MODE,
  isDev:                 import.meta.env.DEV,
  isProd:                import.meta.env.PROD,
});

export function getApiBaseUrl() {
  return _env.apiBaseUrl;
}

export function getApiKey() {
  return _env.apiKey;
}

export function getSupabaseUrl() {
  return _env.supabaseUrl;
}

export function getSupabaseAnonKey() {
  return _env.supabaseAnonKey;
}

export function getOpenAiApiKey() {
  return _env.openaiApiKey;
}

export function getStripePublishableKey() {
  return _env.stripePublishableKey;
}

export function getSentryDsn() {
  return _env.sentryDsn;
}

export function getAnalyticsId() {
  return _env.analyticsId;
}

export function getFeatureFlags() {
  if (!_env.featureFlags) return {};
  try {
    return JSON.parse(_env.featureFlags);
  } catch {
    console.warn('[Trackr] VITE_FEATURE_FLAGS is not valid JSON — returning empty object.');
    return {};
  }
}

export function getAppEnv() {
  return _env.appEnv;
}

export function getAppVersion() {
  return _env.appVersion;
}

export function isDevelopment() {
  return _env.isDev === true;
}

export function isProduction() {
  return _env.isProd === true;
}

export function isTestEnvironment() {
  return _env.mode === 'test';
}

export function getApiHeaders() {
  return Object.freeze({
    'Content-Type': 'application/json',
    'Accept':       'application/json',
    'X-API-Key':    getApiKey(),
  });
}

export function getSupabaseConfig() {
  return Object.freeze({
    url:     getSupabaseUrl(),
    anonKey: getSupabaseAnonKey(),
  });
}

export function getOpenAiConfig() {
  return Object.freeze({
    apiKey:  getOpenAiApiKey(),
    baseUrl: 'https://api.openai.com/v1',
  });
}

export function getStripeConfig() {
  return Object.freeze({
    publishableKey: getStripePublishableKey(),
  });
}

export function getSentryConfig() {
  return Object.freeze({
    dsn:         getSentryDsn(),
    environment: getAppEnv(),
    release:     `trackr@${getAppVersion()}`,
  });
}

export function debugConfig() {
  if (!isDevelopment()) {
    console.warn('[Trackr] debugConfig() is only available in development mode.');
    return null;
  }

  return {
    apiBaseUrl:           getApiBaseUrl(),
    apiKey:               getApiKey()              ? `***${getApiKey().slice(-4)}`              : null,
    supabaseUrl:          getSupabaseUrl(),
    supabaseAnonKey:      getSupabaseAnonKey()     ? `***${getSupabaseAnonKey().slice(-4)}`     : null,
    openaiApiKey:         getOpenAiApiKey()        ? `***${getOpenAiApiKey().slice(-4)}`        : null,
    stripePublishableKey: getStripePublishableKey()
      ? `***${getStripePublishableKey().slice(-4)}`
      : null,
    sentryDsn:            getSentryDsn(),
    analyticsId:          getAnalyticsId(),
    featureFlags:         getFeatureFlags(),
    appEnv:               getAppEnv(),
    appVersion:           getAppVersion(),
    mode:                 _env.mode,
    isDev:                isDevelopment(),
    isProd:               isProduction(),
  };
}

**Fichier 2: .env.example**

# =============================================================================
#  TRACKR — Environment Variables Reference
#  Copy this file to .env.local (never commit .env.local to Git)
#  All VITE_* variables are bundled client-side — NEVER put server-only secrets here
# =============================================================================

# -----------------------------------------------------------------------------
#  🔴  REQUIRED — Build will fail if any of these are missing or empty
# -----------------------------------------------------------------------------

# Base URL of the Trackr REST API (no trailing slash)
# Example: https://api.trackr.app or http://localhost:3001
VITE_API_BASE_URL=

# API key used to authenticate requests to the Trackr backend
# Obtain from your Trackr dashboard → Settings → API Keys
VITE_API_KEY=

# Supabase project URL (found in Supabase dashboard → Settings → API)
# Example: https://xyzxyzxyz.supabase.co
VITE_SUPABASE_URL=

# Supabase anonymous/public key (safe for client-side use)
# Found in Supabase dashboard → Settings → API → anon public
VITE_SUPABASE_ANON_KEY=

# OpenAI API key used for AI-powered features
# Obtain from https://platform.openai.com/account/api-keys
# ⚠️  Restrict this key to only the models/endpoints Trackr needs
VITE_OPENAI_API_KEY=

# -----------------------------------------------------------------------------
#  🟡  OPTIONAL — Features degrade gracefully if these are absent
# -----------------------------------------------------------------------------

# Stripe publishable key for payment features (NOT the secret key)
# Obtain from https://dashboard.stripe.com/apikeys
# Use pk_test_* for development, pk_live_* for production
VITE_STRIPE_PUBLISHABLE_KEY=

# Sentry DSN for error tracking
# Obtain from https://sentry.io → Project → Settings → Client Keys (DSN)
VITE_SENTRY_DSN=

# Analytics tracking ID (Google Analytics / Plausible / Mixpanel etc.)
VITE_ANALYTICS_ID=

# Feature flags as a JSON string — controls experimental features at runtime
# Example: {"newDashboard":true,"betaExport":false}
VITE_FEATURE_FLAGS=

# -----------------------------------------------------------------------------
#  🔵  APP METADATA — Set by CI/CD; override locally if needed
# -----------------------------------------------------------------------------

# Deployment environment identifier
# Valid values: development | staging | production
VITE_APP_ENV=development

# Semantic version of the deployed build (set automatically by CI)
VITE_APP_VERSION=0.0.0