**styles.css**

```css
.root-container {
  padding: 16px;
  background-color: var(--bg);
  box-shadow: 0 0 10px rgba(0, 255, 136, 0.1);
}

body {
  font-family: Inter, sans-serif;
  background-color: var(--bg);
  color: var(--t1);
}

a {
  color: var(--t2);
  text-decoration: none;
}

a:hover {
  color: var(--t3);
}

button {
  background-color: var(--bg2);
  color: var(--t1);
  border: none;
  padding: 10px 16px;
  font-size: 14px;
  cursor: pointer;
}

button:hover {
  background-color: var(--bg3);
}

button:active {
  background-color: var(--t1);
}
