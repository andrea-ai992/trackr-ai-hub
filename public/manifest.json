**public/sw.js**
```javascript
import { registerSW } from 'virtual:windi-sw';
import { CacheFirst, NetworkFirst } from 'virtual:windi-cache';

registerSW({
  // Cache-first pour assets statiques
  cacheName: 'trackr-static',
  cacheOptions: {
    cacheName: 'trackr-static',
    expiration: {
      maxAge: 60 * 60 * 24 * 30, // 30 jours
    },
  },
  matchOptions: {
    ignoreSearch: true,
  },
  fetchOptions: {
    credentials: 'same-origin',
  },
  // Network-first pour API calls
  cacheName: 'trackr-api',
  cacheOptions: {
    cacheName: 'trackr-api',
    expiration: {
      maxAge: 60 * 60 * 24 * 30, // 30 jours
    },
  },
  fetchOptions: {
    credentials: 'same-origin',
  },
  // Fallback offline page simple
  fallback: () => import('./offline.html'),
});
```

