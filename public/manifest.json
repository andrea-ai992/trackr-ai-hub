**public/sw.js**
```javascript
import { CacheFirst } from 'workbox-strategies';
import { CacheableResponsePlugin } from 'workbox-cacheable-response';
import { ExpirationPlugin } from 'workbox-expiration';
import { precacheAndRoute } from 'workbox-precaching';

// Pre-cache les assets statiques
precacheAndRoute(self.__WB_MANIFEST);

// Stratégie de cache-first pour les assets statiques
self.addEventListener('fetch', (event) => {
  if (event.request.mode === 'navigate') {
    event.respondWith(CacheFirst({
      cacheName: 'static-cache',
      plugins: [
        new CacheableResponsePlugin({
          statuses: [0, 200],
        }),
        new ExpirationPlugin({
          maxAgeSeconds: 30 * 24 * 60 * 60, // 30 jours
        }),
      ],
    }).handle(event.request));
  } else if (event.request.url.startsWith(self.location.origin)) {
    event.respondWith(CacheFirst({
      cacheName: 'static-cache',
      plugins: [
        new CacheableResponsePlugin({
          statuses: [0, 200],
        }),
        new ExpirationPlugin({
          maxAgeSeconds: 30 * 24 * 60 * 60, // 30 jours
        }),
      ],
    }).handle(event.request));
  } else {
    event.respondWith(fetch(event.request));
  }
});

// Fallback offline page simple
self.addEventListener('fetch', (event) => {
  if (event.request.url === self.location.origin + '/') {
    event.respondWith(CacheFirst({
      cacheName: 'static-cache',
      plugins: [
        new CacheableResponsePlugin({
          statuses: [0, 200],
        }),
        new ExpirationPlugin({
          maxAgeSeconds: 30 * 24 * 60 * 60, // 30 jours
        }),
      ],
    }).handle(event.request));
  } else {
    event.respondWith(fetch(event.request));
  }
});

// Fallback offline page simple
self.addEventListener('fetch', (event) => {
  if (event.request.url === self.location.origin + '/offline') {
    event.respondWith(CacheFirst({
      cacheName: 'static-cache',
      plugins: [
        new CacheableResponsePlugin({
          statuses: [0, 200],
        }),
        new ExpirationPlugin({
          maxAgeSeconds: 30 * 24 * 60 * 60, // 30 jours
        }),
      ],
    }).handle(event.request));
  } else {
    event.respondWith(fetch(event.request));
  }
});
```

