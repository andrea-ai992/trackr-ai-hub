Création du script de génération des icônes PNG (public/generate-icons.sh):

```bash
#!/bin/bash
# Script pour générer les icônes PNG à partir des SVG
# Nécessite ImageMagick (convert) installé

# Répertoire de sortie
ICON_DIR="public/icons"

# Taille des icônes
SIZES=("96x96")

# Génération des icônes
for size in "${SIZES[@]}"; do
  width=${size%x*}
  height=$width

  # Dashboard
  if [ -f "public/icons/shortcut-dashboard.svg" ]; then
    convert -background none -resize ${width}x${height} public/icons/shortcut-dashboard.svg ${ICON_DIR}/shortcut-dashboard-${size}.png
  fi

  # Sports
  if [ -f "public/icons/shortcut-sports.svg" ]; then
    convert -background none -resize ${width}x${height} public/icons/shortcut-sports.svg ${ICON_DIR}/shortcut-sports-${size}.png
  fi

  # Markets
  if [ -f "public/icons/shortcut-markets.svg" ]; then
    convert -background none -resize ${width}x${height} public/icons/shortcut-markets.svg ${ICON_DIR}/shortcut-markets-${size}.png
  fi

  # News
  if [ -f "public/icons/shortcut-news.svg" ]; then
    convert -background none -resize ${width}x${height} public/icons/shortcut-news.svg ${ICON_DIR}/shortcut-news-${size}.png
  fi

  # Andy
  if [ -f "public/icons/shortcut-andy.svg" ]; then
    convert -background none -resize ${width}x${height} public/icons/shortcut-andy.svg ${ICON_DIR}/shortcut-andy-${size}.png
  fi
done

echo "Icônes générées dans ${ICON_DIR}/"
```

