**styles.css**
```css
:root {
  --green: #00ff88;
  --bg: #080808;
  --bg2: #111;
  --t1: #f0f0f0;
  --t2: #888;
  --t3: #444;
  --border: rgba(255,255,255,0.07);
}

body {
  font-family: 'Inter', sans-serif;
  background-color: var(--bg);
  color: var(--t1);
  padding: 20px;
}

h1 {
  color: var(--green);
}

a {
  color: var(--t2);
  text-decoration: none;
}

a:hover {
  color: var(--t3);
}

.offline {
  display: block;
  text-align: center;
  padding: 20px;
  background-color: var(--bg);
  color: var(--t1);
}