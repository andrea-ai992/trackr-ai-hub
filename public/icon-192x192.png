Je vais ajouter les shortcuts PWA dans manifest.json et générer l'icône manquante. Voici les modifications :

Fichier: public/manifest.json
```json
{
  "name": "Trackr AI",
  "short_name": "Trackr",
  "description": "Dashboard intelligent avec IA pour suivre vos données en temps réel",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#080808",
  "theme_color": "#00ff88",
  "icons": [
    {
      "src": "icon-192x192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "icon-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "icon-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "shortcuts": [
    {
      "name": "Dashboard",
      "short_name": "Dashboard",
      "description": "Accéder au tableau de bord principal",
      "url": "/dashboard",
      "icons": [{
        "src": "icon-dashboard-96x96.png",
        "sizes": "96x96",
        "type": "image/png"
      }]
    },
    {
      "name": "Sports",
      "short_name": "Sports",
      "description": "Suivre les scores et statistiques sportives",
      "url": "/sports",
      "icons": [{
        "src": "icon-sports-96x96.png",
        "sizes": "96x96",
        "type": "image/png"
      }]
    },
    {
      "name": "Markets",
      "short_name": "Markets",
      "description": "Suivre les marchés financiers et crypto",
      "url": "/markets",
      "icons": [{
        "src": "icon-markets-96x96.png",
        "sizes": "96x96",
        "type": "image/png"
      }]
    },
    {
      "name": "News",
      "short_name": "News",
      "description": "Lire les dernières actualités",
      "url": "/news",
      "icons": [{
        "src": "icon-news-96x96.png",
        "sizes": "96x96",
        "type": "image/png"
      }]
    }
  ],
  "related_applications": [],
  "prefer_related_applications": false
}
```

